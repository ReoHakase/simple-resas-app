    "patch-package": "8.0.0",
    "playwright": "1.50.1",
    "prettier": "3.4.2",
    "tsup": "8.3.6",
    "turbo": "2.4.0",
    "typescript": "5.7.3",
    "vite": "6.0.11",
    "vitest": "3.0.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.0.11",
